{
	"name": "drmclaw-core",
	"version": "0.1.0",
	"description": "Open source AI workflow automation engine for Dr. MClaw",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./sdk": {
			"import": "./dist/sdk.js",
			"types": "./dist/sdk.d.ts"
		},
		"./connectors": {
			"import": "./dist/connectors.js",
			"types": "./dist/connectors.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"drmclaw": "./dist/cli.js"
	},
	"files": ["dist", "skills"],
	"scripts": {
		"dev": "tsx watch src/cli.ts",
		"build": "rm -rf dist && tsc",
		"check": "tsc --noEmit -p tsconfig.check.json",
		"start": "node dist/cli.js",
		"test": "vitest run",
		"test:real": "vitest run --config vitest.real.config.ts",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.16.0",
		"@hono/node-server": "^1.19.0",
		"@hono/node-ws": "^1.3.0",
		"c12": "^2.0.0",
		"croner": "^9.0.0",
		"gray-matter": "^4.0.3",
		"hono": "^4.0.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
